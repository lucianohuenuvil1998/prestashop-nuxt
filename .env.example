# ─── PrestaShop 8 WebService ──────────────────────────────────────────────────
# URL base de tu tienda PrestaShop (sin /api al final)
NUXT_PRESTASHOP_BASE_URL=https://tu-tienda.com

# API Key del WebService (Parámetros avanzados → Webservice → Agregar nueva clave)
NUXT_PRESTASHOP_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Feature flag ─────────────────────────────────────────────────────────────
# Cambia a true para usar la API real de PS en vez de los datos de prueba
USE_PRESTASHOP=false

# ─── Módulo custom de auth (futuro) ───────────────────────────────────────────
# URL base del módulo que gestiona login/register de customers
# NUXT_PRESTASHOP_MODULE_URL=https://tu-tienda.com/module/headlessauth
